# VoxCPM2 Inference Dockerfile
# Kullanım:
#   docker build -f Dockerfile.inference -t voxcpm2:latest .
#   docker run --gpus all --rm -it voxcpm2:latest

ARG CUDA_IMAGE=nvidia/cuda:12.4.1-devel-ubuntu22.04

FROM ${CUDA_IMAGE}

ENV DEBIAN_FRONTEND=noninteractive \
    PYTHONUNBUFFERED=1

WORKDIR /app

# Sistem bağımlılıkları
RUN apt-get update && apt-get install -y --no-install-recommends \
    ca-certificates \
    build-essential \
    ninja-build \
    git \
    python3-dev \
    python3-pip \
    ffmpeg \
    libsndfile1-dev \
    && rm -rf /var/lib/apt/lists/*

RUN pip install --no-cache-dir --upgrade pip && ln -sf /usr/bin/python3 /usr/bin/python

# Torch (CUDA 12.4)
RUN pip install --no-cache-dir torch==2.5.1 torchaudio==2.5.1 \
    --index-url https://download.pytorch.org/whl/cu124

# Diğer bağımlılıklar
RUN pip install --no-cache-dir \
    transformers>=4.51.0 \
    soundfile>=0.13.1 \
    librosa \
    numpy \
    tqdm \
    xxhash \
    pydantic \
    huggingface_hub

# flash-attn (torch'u build ortamında görmesi için --no-build-isolation)
RUN pip install --no-cache-dir psutil && pip install --no-cache-dir flash-attn --no-build-isolation

# Kaynak kodu kopyala ve kur
COPY . .
RUN pip install -e . --no-deps --no-cache-dir

ENV MODEL_DIR=/models/VoxCPM2

CMD ["python3", "voxcpm2_run.py"]
